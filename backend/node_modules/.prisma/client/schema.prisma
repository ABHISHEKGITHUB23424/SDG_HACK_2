generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  role         String @default("STAFF")
  passwordHash String
}

model Student {
  id              String        @id @default(cuid())
  name            String
  rollNo          String        @unique
  year            Int           @default(2024)
  department      String        @default("CSE")
  passwordHash    String        @default("password123")
  cgpa            Float
  githubId        String?
  hackathonCount  Int           @default(0)
  semesterHistory String // Store as JSON string since sqlite doesn't support JSON array directly
  participants    Participant[]
  odRequests      ODRequest[]
  riskReports     RiskReport[]
}

model Contest {
  id           String        @id @default(cuid())
  title        String
  startTime    DateTime
  participants Participant[]
}

model Participant {
  id        String @id @default(cuid())
  contestId String
  studentId String
  status    String @default("PENDING")

  contest Contest @relation(fields: [contestId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model ODRequest {
  id             String @id @default(cuid())
  studentId      String
  teamId         String
  cgpa           Float
  hackathonCount Int
  status         String
  reason         String

  student Student @relation(fields: [studentId], references: [id])
}

model RiskReport {
  id                String   @id @default(cuid())
  studentId         String
  semester          Int
  participationDrop Float
  aiSummary         String
  createdAt         DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}
